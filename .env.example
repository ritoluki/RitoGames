# Copy to .env.local and fill values from Supabase → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Public client key — UI may label this "Publishable default" or "anon" (same key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Legacy name (optional): same value as above if your dashboard still says "anon"
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: "Secret" / service_role in API settings — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
